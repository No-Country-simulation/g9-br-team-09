# Este arquivo é apenas um modelo versionado. As credenciais reais devem ficar fora do repositório.
# Linux / WSL / macOS: copie o conteúdo para ~/.config/energiai/oci.env.
# Windows PowerShell: copie o conteúdo para $HOME\.config\energiai\oci.env.
# Nunca copie ou versione credenciais reais neste repositório.
SPRING_PROFILES_ACTIVE=oci

# JDBC Thin com TLS sem wallet obtida no OCI Console.
DB_URL='<oci_tls_jdbc_url>'
DB_USERNAME='<oracle_application_username>'
DB_PASSWORD='<oracle_application_password>'

DB_CONNECT_RETRIES=5
DB_POOL_MIN_IDLE=1
DB_POOL_MAX_SIZE=5
DB_CONNECTION_TIMEOUT_MS=30000
DB_VALIDATION_TIMEOUT_MS=5000
DB_KEEPALIVE_TIME_MS=120000

# Integração ML, quando necessária no ambiente OCI
ML_API_BASE_URL=http://localhost:8000
ML_API_CONNECT_TIMEOUT=2s
ML_API_READ_TIMEOUT=5s
